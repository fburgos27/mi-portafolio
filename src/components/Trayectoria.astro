<section class="trayectoria" id="trayectoria">

    <div class="sobre-etiqueta">
        <span>03</span>
        <p>Trayectoria</p>
    </div>

    <div class="trayectoria-contenido">

        <div class="trayectoria-izq">
            <h2>Del análisis<br>al <span>desarrollo.</span></h2>
            <p class="tray-sub">~3 años conectando datos, contextos institucionales y herramientas de IA en las principales instituciones educativas de Chile.</p>

            <div class="timeline">
                {experiencia.map((e) => (
                    <div class="tl-item">
                        <span class="tl-fecha">{e.fecha}</span>
                        <p class="tl-rol">{e.rol}</p>
                        <p class="tl-lugar">{e.lugar}</p>
                        <p class="tl-desc">{e.desc}</p>
                    </div>
                ))}
            </div>
        </div>

        <div class="trayectoria-der">
            <p class="lateral-titulo">Certificaciones</p>
            <div class="cert-lista">
                {certificaciones.map((c) => (
                    <div class="cert-item">
                        <span class="cert-org">{c.org}</span>
                        <span class="cert-nombre">{c.nombre}</span>
                    </div>
                ))}
            </div>
        </div>

    </div>

</section>